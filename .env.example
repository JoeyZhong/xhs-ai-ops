# 复制本文件为 .env 再填真实值。切勿提交真实 .env。

# 小红书登录 Cookie（浏览器登录后从任意请求头复制）
COOKIES=''

# 存储后端：local（本地文件，开箱即用）| postgres（多租户）
STORAGE_BACKEND=local

# 仅 postgres 模式需要
DATABASE_URL=''

# 鉴权与列加密（自行生成随机串；postgres / JWT 模式需要）
JWT_SECRET=''
MASTER_ENCRYPTION_KEY=''

# 采集器：native（项目自带签名）| fixture（离线假数据）| sidecar
XHS_COLLECTOR=native
